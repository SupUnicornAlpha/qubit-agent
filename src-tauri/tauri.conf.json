{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QUBIT",
  "version": "0.1.0",
  "identifier": "app.qubit.agent",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run --cwd ../frontend dev",
    "beforeBuildCommand": "bun run --cwd ../frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "QUBIT — 量化研究 Agent 平台",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
