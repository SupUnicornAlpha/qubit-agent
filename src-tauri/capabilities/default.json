{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window: core plugins, shell open URL, backend sidecar commands",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:default",
    "http:default",
    "allow-backend-commands",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "qubit",
          "sidecar": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "qubit",
          "sidecar": true
        }
      ]
    }
  ]
}
