{
  "name": "qubit-agent",
  "version": "0.1.0",
  "description": "QUBIT - Open-source quantitative research Agent platform",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:backend": "bash scripts/dev-backend.sh",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:tauri": "tauri dev",
    "build": "bash scripts/build-backend.sh dist/qubit",
    "build:app": "bash scripts/build-app.sh",
    "build:app:release": "bash scripts/build-app.sh --tauri",
    "build:tauri": "tauri build",
    "tauri": "tauri",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/sqlite/migrate.ts",
    "seed:agent-definitions": "bun run src/runtime/seed-agent-definitions.ts",
    "seed:recommended-mcp": "bun run src/runtime/seed-recommended-mcp-servers.ts",
    "sync:fsi-vendor": "bash scripts/sync-fsi-vendor.sh",
    "sync:workspace-agents": "bun run src/scripts/sync-workspace-agents-json.ts",
    "init:agent-packs": "bun run src/scripts/init-quant-agent-pack-prompts.ts",
    "acceptance:langgraph": "bun run src/runtime/langgraph/minimum-acceptance.ts",
    "mcp-bridge": "bun run src/runtime/loop/mcp-bridge-server.ts",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check src",
    "test": "bun test"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.2-r.1",
    "@lancedb/lancedb": "^0.17.0",
    "bun-types": "^1.3.14",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "openai": "^4.103.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@duckdb/node-bindings-darwin-arm64": "1.5.2-r.1",
    "@duckdb/node-bindings-darwin-x64": "1.5.2-r.1",
    "@duckdb/node-bindings-linux-arm64": "1.5.2-r.1",
    "@duckdb/node-bindings-linux-x64": "1.5.2-r.1",
    "@duckdb/node-bindings-win32-arm64": "1.5.2-r.1",
    "@duckdb/node-bindings-win32-x64": "1.5.2-r.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tauri-apps/cli": "^2.8.0",
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.0"
  }
}
