{
  "name": "qubit-agent",
  "version": "0.1.0",
  "description": "QUBIT - Open-source quantitative research Agent platform",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:frontend": "bun run --cwd frontend dev",
    "build": "bun build --compile src/cli.ts --outfile dist/qubit",
    "build:tauri": "bun tauri build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/sqlite/migrate.ts",
    "seed:agent-definitions": "bun run src/runtime/seed-agent-definitions.ts",
    "acceptance:langgraph": "bun run src/runtime/langgraph/minimum-acceptance.ts",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check src",
    "test": "bun test"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.2-r.1",
    "@lancedb/lancedb": "^0.17.0",
    "@langchain/core": "^0.3.32",
    "@langchain/langgraph": "^0.2.39",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "openai": "^4.103.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.8.0"
  }
}
